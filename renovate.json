{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Tokyo",
  "enabledManagers": ["mise"],
  "mise": {
    "managerFilePatterns": ["/^home/dot_config/mise/config\\.toml$/"]
  },
  "minimumReleaseAge": "7 days",
  "automerge": true,
  "automergeType": "pr",
  "ignoreTests": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0
}
