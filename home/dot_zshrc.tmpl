# git-completionの読み込み
fpath=(~/.zsh $fpath)
zstyle ':completion:*:*:git:*' script ~/.zsh/git-completion.bash
autoload -Uz compinit && compinit

# PATH
typeset -U path PATH
path=(
  /opt/homebrew/bin(N-/)
  /opt/homebrew/sbin(N-/)
  /usr/bin
  /usr/sbin
  /bin
  /sbin
  /usr/local/bin(N-/)
  /usr/local/sbin(N-/)
  /Library/Apple/usr/bin
)

export PATH="$HOME/.local/bin:$PATH"

# Rancher Desktop
if [ -d "$HOME/.rd/bin" ]; then
  export PATH="$HOME/.rd/bin:$PATH"
fi

# mise (replaces nvm + manages pnpm)
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
  # shims を PATH に追加（sudo env "PATH=$PATH" で引き継ぐため）
  export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

# sudo でも mise 管理ツール（pnpm 等）を使えるようにする
alias sudo='sudo env "PATH=$PATH"'

{{ if eq .chezmoi.os "darwin" -}}
# SSH Agent (Secretive - macOS only)
export SSH_AUTH_SOCK="$HOME/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh"
{{ end -}}

# Google Cloud SDK
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then
  source "$HOME/google-cloud-sdk/path.zsh.inc"
fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then
  source "$HOME/google-cloud-sdk/completion.zsh.inc"
fi

# aliases
alias st='git status'
alias f='git fetch --prune --all'
alias br='git branch'
alias sw='git switch'
alias co='git checkout'

# Claude Code helpers
[ -f "$HOME/.zsh/ccstyle.zsh" ] && source "$HOME/.zsh/ccstyle.zsh"

# Starship prompt
eval "$(starship init zsh)"

# Local overrides (secrets, machine-specific settings)
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

{{ if eq .chezmoi.os "linux" -}}
# Turso
export PATH="$PATH:/home/mittsmasa/.turso"
{{ end -}}
